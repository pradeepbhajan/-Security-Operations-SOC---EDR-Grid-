<!-- Custom Brute Force Detection Rules for Sentient Shield -->
<!-- Active Response Trigger Rules -->

<group name="authentication,brute_force,sentient_shield">

  <!-- SSH Brute Force Detection -->
  <rule id="100101" level="10" frequency="5" timeframe="300">
    <if_matched_sid>5710</if_matched_sid>
    <same_source_ip />
    <description>SSH brute force attack detected from $(srcip) - 5 failed attempts in 5 minutes</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
  </rule>

  <!-- RDP Brute Force Detection -->
  <rule id="100102" level="10" frequency="5" timeframe="300">
    <if_matched_sid>60122</if_matched_sid>
    <same_source_ip />
    <description>RDP brute force attack detected from $(srcip) - Multiple failed login attempts</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
  </rule>

  <!-- Web Application Brute Force -->
  <rule id="100103" level="9" frequency="10" timeframe="120">
    <if_matched_sid>31101</if_matched_sid>
    <same_source_ip />
    <description>Web application brute force from $(srcip) - Multiple 401/403 responses</description>
    <mitre>
      <id>T1110.002</id>
    </mitre>
  </rule>

  <!-- FTP Brute Force -->
  <rule id="100104" level="9" frequency="5" timeframe="300">
    <if_matched_sid>11104</if_matched_sid>
    <same_source_ip />
    <description>FTP brute force attack from $(srcip)</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
  </rule>

  <!-- MySQL/Database Brute Force -->
  <rule id="100105" level="9" frequency="5" timeframe="300">
    <match>authentication failure|Access denied</match>
    <same_source_ip />
    <description>Database brute force attack from $(srcip)</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
  </rule>

  <!-- Successful Login After Brute Force -->
  <rule id="100106" level="12">
    <if_sid>5715</if_sid>
    <if_matched_sid>100101</if_matched_sid>
    <same_source_ip />
    <description>Successful SSH login from $(srcip) after brute force attempts - CRITICAL</description>
    <mitre>
      <id>T1110.001</id>
      <id>T1078</id>
    </mitre>
  </rule>

  <!-- Password Spray Attack -->
  <rule id="100107" level="11" frequency="20" timeframe="600">
    <if_matched_sid>5710</if_matched_sid>
    <different_user />
    <same_source_ip />
    <description>Password spray attack detected from $(srcip) - Multiple users targeted</description>
    <mitre>
      <id>T1110.003</id>
    </mitre>
  </rule>

  <!-- Credential Stuffing -->
  <rule id="100108" level="10" frequency="15" timeframe="180">
    <if_matched_sid>31101</if_matched_sid>
    <same_source_ip />
    <description>Credential stuffing attack from $(srcip) - Automated login attempts</description>
    <mitre>
      <id>T1110.004</id>
    </mitre>
  </rule>

  <!-- Distributed Brute Force -->
  <rule id="100109" level="11" frequency="10" timeframe="600">
    <if_matched_sid>5710</if_matched_sid>
    <different_srcip />
    <description>Distributed brute force attack - Multiple IPs targeting same account</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
  </rule>

  <!-- Account Lockout Triggered -->
  <rule id="100110" level="8">
    <match>account locked|user locked</match>
    <description>User account $(user) locked due to failed login attempts</description>
    <mitre>
      <id>T1110</id>
    </mitre>
  </rule>

</group>
